# Copie para .env e ajuste (docker compose carrega .env automaticamente na raiz do projeto)
POSTGRES_DB=mural_esg
POSTGRES_USER=mural
POSTGRES_PASSWORD=mural
POSTGRES_PORT=5432

APP_PORT=8080

# update | validate | none — localmente costuma ser "update"
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Login da interface (seed na primeira execução)
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_PASSWORD=admin
APP_SEED_USER_USERNAME=usuario
APP_SEED_USER_PASSWORD=usuario
